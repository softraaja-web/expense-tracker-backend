# ─── GPay Transaction Extractor - Environment Variables ─────────────
# Copy this file to .env and fill in your values

# Supabase Configuration
# Get from: Project Settings -> API
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_service_role_key_here

# Firebase Configuration
# Path to the Firebase Admin SDK service account key JSON file
FIREBASE_CREDENTIALS_JSON="path/to/firebase-adminsdk.json"

# Google Gemini API Key (for LLM fallback parsing)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Tesseract OCR Path
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: /usr/bin/tesseract (usually auto-detected)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# App Settings
DEBUG=false
CORS_ORIGINS=*
